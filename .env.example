# Local-only secrets should go in .env.local, not in tracked files.
# If a key is present, the model-backed Analyst, Critic, Planner, and follow-up path is enabled automatically.

# Best default reasoning model from your current account access.
IIRS_AGENT_MODEL=gpt-5-mini
IIRS_OPENAI_REASONING_EFFORT=low

# Keep this unset unless you start indexing runbooks or other text corpora.
IIRS_EMBEDDING_MODEL=text-embedding-3-small

# Set your real key in .env.local.
OPENAI_API_KEY=
